<%- include('../partials/header', { title: 'YouList - Movies' }) %>

  <main class="youlist-container">
    <!-- Hero Section -->
    <section class="hero-section gradient-background">
      <h1 class="gradient-text">YouList - Movies</h1>
    </section>

    <!-- Search/Sort Bar -->
    <section class="search-sort-bar">
      <form class="search-form" onsubmit="return false;">
        <div class="search-wrapper">
          <input type="text" name="search"  placeholder="Search movies..." class="search-input">
          <button type="button" name="button" class="clear-input">×</button>
          <!-- Autocomplete dropdown appended by JS -->
        </div>
      </form>
    </section>

    <!-- Temporary movie card (hidden) -->
    <section class="movielist-section temporary movie-card" id="temp-card" style="display:none;">

      <div class="movie-poster">
        <img id="temp-poster" src="/project34/images/placeholder.png" alt="Movie Poster">
      </div>
      <div class="Details">
        <div class="Title">
          <h2 id="temp-title">Movie Title</h2>
        </div>
        <div class="Director">
          <h3 id="temp-director">Director: N/A</h3>
        </div>
        <div class="ReleaseYear">
          <h3 id="temp-year">Release Year: N/A</h3>
        </div>
        <div class="Genre">
          <h3 id="temp-genre">Genre: N/A</h3>
        </div>
        <div class="Cast">
          <h3 id="temp-cast">Stars: N/A</h3>
        </div>
        <div class="CommentsSection">
          <textarea id="temp-comment" class="user-comment" aria-label="Movie comment"
            placeholder="Add your comment..."></textarea>
          <div class="comment-buttons">
            <button id="submit-comment">Submit</button>
            <button id="cancel-comment">Cancel</button>
          </div>
        </div>
      </div>
    </section>

    <!-- Movie list container -->
    <section id="movie-list" class="movie-list-grid"></section>

    <!-- Pagination -->
    <div class="pagination">
      <button id="prev-page">Prev</button>
      <button id="next-page" disabled>Next</button>
    </div>
    <script>
      window.currentUser = <%- JSON.stringify(user || null) %>;
    </script>
  </main>

  <%- include('../partials/footer') %>