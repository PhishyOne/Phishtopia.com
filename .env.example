# Server
PORT=3002
NODE_ENV=development
SESSION_SECRET=

# Optional debug logging
LOG_SESSIONS=false
LOG_UNIQUE_STATIC_IPS=false

# Database option 1: full connection string
# Recommended for Heroku, Cloud SQL connectors, and many hosted Postgres providers.
DATABASE_URL=

# Database option 2: split connection settings
# Used when DATABASE_URL is not set.
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_NAME=
DB_PORT=5432
DB_SSL=

# TMDB API
TMDB_API_KEY=

# Email verification / SMTP
EMAIL_USER=
EMAIL_PASS=
