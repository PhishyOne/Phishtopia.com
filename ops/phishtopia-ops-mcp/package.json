{
  "name": "phishtopia-ops-mcp",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.16.0 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format:check": "prettier --check .",
    "test": "npm run build && node --test dist/test/*.test.js",
    "smoke": "npm run build && node dist/smoke/protocol-smoke.js",
    "smoke:live": "npm run build && node dist/smoke/live-smoke.js",
    "audit": "npm audit --omit=dev --audit-level=moderate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "prettier": "3.9.5",
    "typescript": "7.0.2"
  }
}
